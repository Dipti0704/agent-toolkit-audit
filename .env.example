# Copy this file to .env and fill in real values. Never commit .env.

# Composio -- app.composio.dev -> Settings -> API Keys
COMPOSIO_API_KEY=

# OpenAI -- platform.openai.com -> API Keys
OPENAI_API_KEY=

# Model used by the research/verification agents. gpt-5.4-nano is OpenAI's
# cheapest model that still supports tool/function calling -- good enough for
# structured extraction from docs pages. Bump to gpt-5.4-mini if nano's
# extractions look shaky on trickier apps (still cheap, noticeably sharper).
RESEARCH_MODEL=gpt-5.4-nano

# Max concurrent agent calls when fanning out across the 100 apps.
# Kept low by default -- many OpenAI account tiers cap tokens-per-minute (TPM)
# well below what 8+ concurrent research loops would need. Raise this if your
# account's TPM limit is high; the pipeline retries 429s with backoff either way.
MAX_CONCURRENCY=3
